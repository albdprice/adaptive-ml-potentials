\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Learning curves for the Rose/UBER system (left panels) and Lennard-Jones system (right panels). For each: extrapolation MAE versus training set size with power-law fits, interpolation MAE, and ratio of direct to adaptive MAE (values $>1$ indicate adaptive advantage). Shaded regions indicate $\pm 1$ standard deviation over 5 random seeds. The dashed lines show power-law fits $\mathrm  {MAE} \propto N^{-\beta }$ with exponents $\beta $ as indicated.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:learning_curves}{{5}{7}{Learning curves for the Rose/UBER system (left panels) and Lennard-Jones system (right panels). For each: extrapolation MAE versus training set size with power-law fits, interpolation MAE, and ratio of direct to adaptive MAE (values $>1$ indicate adaptive advantage). Shaded regions indicate $\pm 1$ standard deviation over 5 random seeds. The dashed lines show power-law fits $\mathrm {MAE} \propto N^{-\beta }$ with exponents $\beta $ as indicated}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Force prediction comparison for extrapolation test sets ($N = 100$ training samples). (a--c)~LJ system: example energy curves, example gradients $dV/dr$, and gradient parity plot. The adaptive approach provides analytic gradients with $R^2 = 0.998$, while direct numerical differentiation yields $R^2 = 0.109$. (d--f)~Rose/UBER system: the Rose gradient approximates the true Morse gradient with $R^2 = 0.999$.}}{7}{figure.6}\protected@file@percent }
\newlabel{fig:forces}{{6}{7}{Force prediction comparison for extrapolation test sets ($N = 100$ training samples). (a--c)~LJ system: example energy curves, example gradients $dV/dr$, and gradient parity plot. The adaptive approach provides analytic gradients with $R^2 = 0.998$, while direct numerical differentiation yields $R^2 = 0.109$. (d--f)~Rose/UBER system: the Rose gradient approximates the true Morse gradient with $R^2 = 0.999$}{figure.6}{}}
\newlabel{eq:rose_force}{{12}{7}{}{equation.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {F}Delta learning}{7}{section*.21}\protected@file@percent }
\newlabel{sec:delta}{{IV\,F}{7}{}{section*.21}{}}
\newlabel{eq:delta}{{13}{7}{}{equation.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Delta learning comparison for Rose/UBER (top) and LJ (bottom) systems. (a,d)~Example extrapolation predictions showing direct (gray), adaptive (blue), and delta (orange). (b,e)~Learning curves for extrapolation MAE versus training set size. (c,f)~Ratio of direct MAE to adaptive/delta MAE (values $>1$ indicate advantage over direct). For Rose/UBER, where the physics equation is approximate, delta improves $2.7\times $ over pure adaptive. For LJ, where the physics is exact, delta provides only marginal improvement ($1.03\times $).}}{8}{figure.7}\protected@file@percent }
\newlabel{fig:delta}{{7}{8}{Delta learning comparison for Rose/UBER (top) and LJ (bottom) systems. (a,d)~Example extrapolation predictions showing direct (gray), adaptive (blue), and delta (orange). (b,e)~Learning curves for extrapolation MAE versus training set size. (c,f)~Ratio of direct MAE to adaptive/delta MAE (values $>1$ indicate advantage over direct). For Rose/UBER, where the physics equation is approximate, delta improves $2.7\times $ over pure adaptive. For LJ, where the physics is exact, delta provides only marginal improvement ($1.03\times $)}{figure.7}{}}
